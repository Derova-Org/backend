{
  "name": "derova-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --test --experimental-test-module-mocks --import tsx $(find test -name '*.test.ts' -not -path 'test/e2e/*')",
    "test:coverage": "c8 node --test --experimental-test-module-mocks --import tsx $(find test -name '*.test.ts' -not -path 'test/e2e/*')",
    "test:e2e": "bash scripts/run-e2e.sh",
    "lint": "eslint 'src/**/*.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@derova/sdk": "file:../sdk",
    "@hashgraph/sdk": "^2.56.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.18.0",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.1"
  }
}
